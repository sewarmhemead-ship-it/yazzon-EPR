# .env.example — متغيرات الواجهة (Vite). انسخه إلى .env واملأ القيم.
# ملاحظة: مفاتيح Vite العامة يجب أن تبدأ بـ VITE_ (تُضمَّن في حزمة المتصفح — لا تضع هنا أسراراً خادمية).

# عنوان مشروع Supabase ومفتاح anon العام (من Supabase Dashboard → Settings → API).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# عنوان الـ backend API. اتركه فارغاً غالباً:
# - التطوير: Vite proxy يمرر /api إلى http://localhost:3000
# - الإنتاج/Railway: Express يخدم الواجهة والـ API على نفس الدومين
# VITE_API_URL=/api
